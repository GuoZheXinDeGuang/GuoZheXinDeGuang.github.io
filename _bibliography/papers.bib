@article{zhu2026sysnav,
  abbr       = {arXiv},
  title      = {SysNav: Multi-Level Systematic Cooperation Enables Real-World, Cross-Embodiment Object Navigation},
  author     = {Zhu, Haokun and Li, Zongtai and Liu, Zihan and Guo, Kevin and Lin, Zhengzhi and Cai, Yuxin and Chen, Guofei and Lv, Chen and Wang, Wenshan and Oh, Jean and Zhang, Ji},
  journal    = {arXiv preprint arXiv:2603.06914},
  year       = {2026},
  html       = {https://arxiv.org/abs/2603.06914},
  pdf        = {https://arxiv.org/pdf/2603.06914},
  website    = {https://cmu-vln.github.io/},
  code       = {https://github.com/zwandering/SysNav},
  preview    = {sysnav-overview.png},
  selected   = {true},
  abstract   = {SysNav is a three-level object navigation system that decouples semantic reasoning, room-based navigation planning, and embodiment-specific motion control. It generalizes across wheeled, quadruped, and humanoid robots and reports 190 real-world experiments with strong gains in navigation efficiency over prior baselines.}
}

@article{sheng2026langscd,
  abbr       = {arXiv},
  title      = {Scene Change Detection with Vision-Language Representation Learning},
  author     = {Sheng, Diwei and Gohil, Vijayraj and Gaba, Satyam and Liu, Zihan and Hamilton-Fletcher, Giles and Rizzo, John-Ross and Liang, Yongqing and Feng, Chen},
  journal    = {arXiv preprint arXiv:2604.11402},
  year       = {2026},
  html       = {https://arxiv.org/abs/2604.11402},
  pdf        = {https://arxiv.org/pdf/2604.11402},
  code       = {https://github.com/ai4ce/LangSCD},
  preview    = {https://arxiv.org/html/2604.11402v1/figs/qualitative_result.png},
  selected   = {true},
  abstract   = {LangSCD introduces a vision-language framework for scene change detection that uses language-guided semantic reasoning, cross-modal feature enhancement, and geometric-semantic matching. The work also introduces NYC-CD, a large-scale dataset with multiclass scene-change annotations for real-world urban imagery.}
}
